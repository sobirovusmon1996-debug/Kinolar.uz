# Example environment variables for Kinolar_bot
# Copy this to a file named .env (for local development) or set these as environment variables in Railway.

BOT_TOKEN=your_telegram_bot_token_here
MONGO_URI=your_mongodb_uri_here
ADMIN_ID=123456789

# Example MONGO_URI (replace with your credentials):
# MONGO_URI=mongodb+srv://user:password@cluster0.mongodb.net/?retryWrites=true&w=majority
